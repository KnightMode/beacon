# Copy to .dev.vars at the REPO ROOT (not here). Used by: npm run dev:portal
# See repo root .dev.vars — wrangler loads secrets from the project root only.

ADMIN_SESSION_SECRET=
ADMIN_CF_ACCESS_ISSUER=
ADMIN_CF_ACCESS_AUD=
ADMIN_CF_ACCESS_ALLOWED_EMAILS=
ADMIN_CF_ACCESS_ALLOWED_DOMAINS=
