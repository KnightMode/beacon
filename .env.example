# =============================================================================
# Slack Code Intelligence Bot — environment variables / secrets reference
# =============================================================================
# Copy this file where appropriate:
#   - For the indexer (services/indexer):   cp .env.example services/indexer/.env
#   - For Workers, set secrets with:        wrangler secret put <NAME>
#     (do NOT commit real values; Workers read [vars] from wrangler.toml and
#      secrets from the secret store)
#
# Anything marked SECRET must be set via `wrangler secret put` for Workers,
# never placed in [vars] in wrangler.toml.
# =============================================================================

# ---- GitHub access (the single indexing identity) ---------------------------
# Fine-grained PAT with "Contents: Read-only" on the allowlisted repos.
# For slack-bot PR review: also grant "Pull requests: Read".
# For create-PR from Slack: also grant "Contents: Write" and "Pull requests: Write".
# Set on the indexer (.env) and on slack-bot (wrangler secret put GITHUB_PAT).
GITHUB_PAT=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx                       # SECRET

# Default owner/repo when a create-PR issue does not name a repo (slack-bot [vars]).
DEFAULT_PR_REPO=KnightMode/slack-code-intelligence

# Optional GitHub App support (stubbed). Leave blank to use the PAT.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=                                             # SECRET
GITHUB_APP_INSTALLATION_ID=

# Secret used to verify GitHub webhook HMAC (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string            # SECRET

# ---- Slack ------------------------------------------------------------------
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret             # SECRET
SLACK_BOT_TOKEN=xoxb-replace-with-bot-token                        # SECRET

# ---- Admin / internal -------------------------------------------------------
# Bearer token protecting POST /admin/index on the github-webhook worker.
ADMIN_TOKEN=replace-with-a-long-random-string                      # SECRET

# Shared secret the queue consumer uses to call the indexer HTTP service.
INDEXER_SHARED_SECRET=replace-with-a-long-random-string            # SECRET

# Base URL of the deployed indexer HTTP service (Node service / container).
INDEXER_URL=https://your-indexer.example.com

# ---- Cloudflare REST API (used by the Node indexer service) -----------------
# The indexer is a Node process and cannot use Worker bindings, so it talks to
# D1 / Vectorize / Workers AI over the Cloudflare REST API.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token                     # SECRET
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
CLOUDFLARE_VECTORIZE_INDEX=code-chunks

# ---- Model IDs (configurable) ----------------------------------------------
EMBEDDING_MODEL=@cf/google/embeddinggemma-300m
EMBEDDING_DIMENSIONS=768
LLM_MODEL=@cf/moonshotai/kimi-k2.6

# ---- Repo allowlist (comma-separated owner/name) ----------------------------
# Seed for the prototype_repo_allowlist table; the indexer/admin can also seed.
REPO_ALLOWLIST=your-org/your-repo,your-org/another-repo
